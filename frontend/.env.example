# AICES Frontend Environment Variables
# Copy this file to .env.local in development or set these in your deployment platform

# Backend API URL
# Local development: http://127.0.0.1:8000 (FastAPI on localhost)
# Production: https://your-aices-backend.onrender.com (set in Vercel)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Demo user ID for local testing
# (Replaces with real user auth in production)
VITE_AICES_USER_ID=user_001
