# AICES Backend Environment Variables
# Copy this file to .env in the project root or set these in your deployment platform

# ========== OpenAI Configuration ==========
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ========== Database Configuration ==========
# SQLite for local/demo use:
AICES_DB_PATH=./data/aices.db

# PostgreSQL for production (optional):
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/aices

# ========== CORS Configuration ==========
# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173, http://127.0.0.1:5173
# Production: https://your-aices-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated frontend origins allowed to call the FastAPI backend.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-aices-frontend.vercel.app
